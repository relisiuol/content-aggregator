{
	"$schema": "https://json.schemastore.org/package",
	"name": "content-aggregator",
	"version": "2.1.2",
	"description": "Create WordPress posts from RSS, Atom, WordPress REST API, JSON, and XML sources.",
	"author": "relisiuol",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"aggregator",
		"rss",
		"atom",
		"rest-api",
		"json",
		"xml"
	],
	"homepage": "https://github.com/relisiuol/content-aggregator#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/relisiuol/content-aggregator.git"
	},
	"bugs": {
		"url": "https://github.com/relisiuol/content-aggregator/issues"
	},
	"engines": {
		"node": ">=20 <21",
		"pnpm": ">=10 <11"
	},
	"type": "module",
	"main": "assets/js/content-aggregator.js",
	"dependencies": {
		"@wordpress/i18n": "^6.18.0",
		"jquery": "^3.7.1",
		"jquery-autocomplete": "^1.2.8",
		"select2": "^4.0.13"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@wordpress/e2e-test-utils-playwright": "^1.45.0",
		"@wordpress/env": "^11.5.0",
		"@wordpress/prettier-config": "^4.45.0",
		"@wordpress/scripts": "^32.1.0",
		"copy-webpack-plugin": "^14.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"markdownlint-cli": "^0.48.0",
		"mini-css-extract-plugin": "^2.10.2",
		"stylelint-order": "^8.1.1",
		"svglint": "^4.2.1"
	},
	"scripts": {
		"build": "wp-scripts build",
		"fix:json": "wp-scripts format .markdownlint.json .vscode/extensions.json .vscode/settings.json .wordpress-org/blueprints/blueprint.json .wp-env.json composer.json package.json languages/*.json",
		"fix:php": "composer run cb",
		"format": "wp-scripts format",
		"lint": "pnpm run /^lint:.*/",
		"lint:css": "wp-scripts lint-style \"assets/**/*.scss\"",
		"lint:js": "wp-scripts lint-js",
		"lint:json": "wp-scripts format .markdownlint.json .vscode/extensions.json .vscode/settings.json .wordpress-org/blueprints/blueprint.json .wp-env.json composer.json package.json languages/*.json --check",
		"lint:md": "wp-scripts lint-md-docs",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"lint:php": "composer run cs",
		"lint:svg": "svglint assets/svg/**/*.svg",
		"localize:start": "wp i18n make-pot . languages/content-aggregator.pot",
		"localize:update": "wp i18n update-po languages/content-aggregator.pot",
		"localize:mo": "wp i18n make-mo languages/",
		"localize:json": "wp i18n make-json --no-purge languages/",
		"localize:php": "wp i18n make-php languages/",
		"plugin-zip": "composer install --no-dev --prefer-dist --no-progress --no-interaction && wp-scripts plugin-zip && zip -dq content-aggregator.zip content-aggregator/README.md",
		"prepare": "husky && composer install",
		"start": "wp-scripts start",
		"test:playwright": "wp-scripts test-playwright",
		"wp-env": "wp-env"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.json": [
			"wp-scripts format"
		],
		"assets/js/**/*.{js,ts,jsx,tsx}": [
			"wp-scripts format",
			"wp-scripts lint-js --fix"
		],
		"assets/scss/**/*.{css,scss}": [
			"wp-scripts format",
			"wp-scripts lint-style --fix"
		],
		"assets/svg/**/*.svg": [
			"svglint assets/svg/**/*.svg"
		],
		"package.json": [
			"wp-scripts lint-pkg-json"
		],
		"*.md": [
			"wp-scripts format",
			"markdownlint --fix"
		],
		"*.php": [
			"./includes/vendor/bin/phpcbf --report-summary --report-source",
			"./includes/vendor/bin/phpcs"
		]
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"npmpackagejsonlint": {
		"extends": "@wordpress/npm-package-json-lint-config"
	},
	"prettier": "@wordpress/prettier-config",
	"stylelint": {
		"extends": [
			"@wordpress/stylelint-config/scss"
		],
		"ignoreFiles": [
			"/build",
			"/node_modules",
			"/includes/vendor"
		],
		"plugins": [
			"stylelint-order"
		],
		"rules": {
			"selector-class-pattern": null,
			"order/order": [
				{
					"type": "at-rule"
				},
				"declarations",
				"custom-properties",
				"dollar-variables",
				{
					"type": "at-rule",
					"hasBlock": true
				},
				"less-mixins",
				"rules"
			],
			"order/properties-order": [
				[
					{
						"groupName": "Position",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"position",
							"top",
							"right",
							"bottom",
							"left",
							"z-index",
							"border-box",
							"float",
							"clear"
						]
					},
					{
						"groupName": "Display",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"display",
							"flex",
							"flex-grow",
							"flex-shrink",
							"flex-basis",
							"flex-direction",
							"flex-flow",
							"flex-wrap",
							"grid",
							"grid-area",
							"grid-template",
							"grid-template-areas",
							"grid-template-rows",
							"grid-template-columns",
							"grid-row",
							"grid-row-start",
							"grid-row-end",
							"grid-column",
							"grid-column-start",
							"grid-column-end",
							"grid-auto-rows",
							"grid-auto-columns",
							"grid-auto-flow",
							"grid-gap",
							"grid-row-gap",
							"grid-column-gap",
							"gap",
							"align-content",
							"align-items",
							"align-self",
							"justify-content",
							"order"
						]
					},
					{
						"groupName": "Spacing",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"width",
							"min-width",
							"max-width",
							"height",
							"min-height",
							"max-height",
							"box-sizing",
							"margin",
							"margin-top",
							"margin-right",
							"margin-bottom",
							"margin-left",
							"padding",
							"padding-top",
							"padding-right",
							"padding-bottom",
							"padding-left",
							"object-fit"
						]
					},
					{
						"groupName": "Colors",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"color",
							"background",
							"background-color",
							"background-image",
							"background-attachment",
							"background-position",
							"background-position-x",
							"background-position-y",
							"background-clip",
							"background-origin",
							"background-size",
							"background-repeat"
						]
					},
					{
						"groupName": "Text",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"font",
							"font-family",
							"font-size",
							"line-height",
							"font-weight",
							"font-style",
							"font-variant",
							"font-size-adjust",
							"font-stretch",
							"text-align",
							"text-align-last",
							"text-decoration",
							"text-emphasis",
							"text-emphasis-position",
							"text-emphasis-style",
							"text-emphasis-color",
							"text-indent",
							"text-justify",
							"text-rendering",
							"text-outline",
							"text-transform",
							"text-wrap",
							"text-overflow",
							"text-overflow-ellipsis",
							"text-overflow-mode",
							"text-shadow",
							"letter-spacing",
							"word-spacing",
							"word-wrap",
							"word-break"
						]
					},
					{
						"groupName": "Decors",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"border",
							"border-spacing",
							"border-collapse",
							"border-width",
							"border-style",
							"border-color",
							"border-top",
							"border-top-width",
							"border-top-style",
							"border-top-color",
							"border-right",
							"border-right-width",
							"border-right-style",
							"border-right-color",
							"border-bottom",
							"border-bottom-width",
							"border-bottom-style",
							"border-bottom-color",
							"border-left",
							"border-left-width",
							"border-left-style",
							"border-left-color",
							"border-radius",
							"border-top-left-radius",
							"border-top-right-radius",
							"border-bottom-right-radius",
							"border-bottom-left-radius",
							"border-image",
							"border-image-source",
							"border-image-slice",
							"border-image-width",
							"border-image-outset",
							"border-image-repeat",
							"border-top-image",
							"border-right-image",
							"border-bottom-image",
							"border-left-image",
							"border-corner-image",
							"border-top-left-image",
							"border-top-right-image",
							"border-bottom-right-image",
							"border-bottom-left-image",
							"box-shadow",
							"outline",
							"outline-width",
							"outline-style",
							"outline-color",
							"outline-offset",
							"list-style",
							"list-style-position",
							"list-style-type",
							"list-style-image"
						]
					},
					{
						"groupName": "Tweaks",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"transform",
							"transform-origin",
							"opacity",
							"visibility",
							"cursor",
							"overflow",
							"overflow-x",
							"overflow-y",
							"overflow-scrolling"
						]
					},
					{
						"groupName": "Animations",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"animation",
							"animation-name",
							"animation-duration",
							"animation-play-state",
							"animation-timing-function",
							"animation-delay",
							"animation-iteration-count",
							"animation-direction",
							"animation-fill-mode",
							"transition",
							"transition-delay",
							"transition-timing-function",
							"transition-duration",
							"transition-property"
						]
					},
					{
						"groupName": "Misc",
						"emptyLineBefore": "never",
						"noEmptyLineBetween": true,
						"properties": [
							"pointer-event",
							"content",
							"appearance"
						]
					}
				],
				{
					"unspecified": "bottom",
					"emptyLineBeforeUnspecified": "never"
				}
			]
		}
	}
}
